{
  "name": "agent-console",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "acg": "bin/acg.mjs",
    "agent-console": "bin/acg.mjs"
  },
  "files": [
    "dist",
    "server",
    "scripts",
    "bin",
    "server.mjs"
  ],
  "scripts": {
    "dev": "node server.mjs",
    "build": "vite build",
    "build:standalone": "node build.mjs",
    "start": "NODE_ENV=production node server.mjs",
    "preview": "NODE_ENV=production node server.mjs",
    "serve": "node bin/acg.mjs serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/fix-node-pty-permissions.cjs",
    "prepack": "npm run build",
    "install:acg": "npm run build && npm link"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@vitejs/plugin-react": "5.0.4",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.0.0",
    "vite": "6.4.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
